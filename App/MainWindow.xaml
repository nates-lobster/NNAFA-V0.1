<Window x:Class="NeurofeedbackApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeurofeedbackApp"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="NeuroMemoryStudy Monitor" Height="900" Width="1200"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Status Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Background="#f0f0f0">
            <TextBlock Text="Signal Status:" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <Border x:Name="StatusIndicator" Width="20" Height="20" CornerRadius="10" Background="Gray" Margin="0,0,20,0"/>
            <TextBlock x:Name="StatusText" Text="Waiting..." VerticalAlignment="Center" Margin="0,0,20,0" Width="100"/>
            
            <TextBlock Text="δ (1-4):" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#FF000088"/>
            <TextBlock x:Name="DeltaText" Text="0.00" Width="45" VerticalAlignment="Center"/>
            
            <TextBlock Text="θ (4-8):" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#FF008888"/>
            <TextBlock x:Name="ThetaText" Text="0.00" Width="45" VerticalAlignment="Center"/>
            
            <TextBlock Text="α (8-12):" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#FF008800"/>
            <TextBlock x:Name="AlphaText" Text="0.00" Width="45" VerticalAlignment="Center"/>
            
            <TextBlock Text="β (12-30):" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#FF880000"/>
            <TextBlock x:Name="BetaText" Text="0.00" Width="45" VerticalAlignment="Center"/>

            <TextBlock Text="γ (30-40):" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#FF880088"/>
            <TextBlock x:Name="GammaText" Text="0.00" Width="45" VerticalAlignment="Center"/>
            
            <ComboBox x:Name="RatioNumCombo" Width="65" Margin="15,0,5,0" SelectionChanged="RatioCombo_SelectionChanged">
                <ComboBoxItem Content="Alpha" IsSelected="True"/>
                <ComboBoxItem Content="Theta"/>
                <ComboBoxItem Content="Beta"/>
            </ComboBox>
            <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="RatioDenCombo" Width="65" Margin="0,0,10,0" SelectionChanged="RatioCombo_SelectionChanged">
                <ComboBoxItem Content="Beta" IsSelected="True"/>
                <ComboBoxItem Content="Alpha"/>
                <ComboBoxItem Content="Theta"/>
            </ComboBox>
            <TextBlock Text="Ratio:" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="RatioText" Text="0.00" Width="50" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="5">
            
            <!-- Tab 1: Live Signals -->
            <TabItem Header="Live Signals">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Top Row: Ears -->
                        <ScottPlot:WpfPlot x:Name="EegPlotTP9" Grid.Row="0" Grid.Column="0" Margin="2"/>
                        <ScottPlot:WpfPlot x:Name="EegPlotTP10" Grid.Row="0" Grid.Column="1" Margin="2"/>
                        <!-- Bottom Row: Foreheads -->
                        <ScottPlot:WpfPlot x:Name="EegPlotAF7" Grid.Row="1" Grid.Column="0" Margin="2"/>
                        <ScottPlot:WpfPlot x:Name="EegPlotAF8" Grid.Row="1" Grid.Column="1" Margin="2"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScottPlot:WpfPlot x:Name="FftPlot" Grid.Column="0"/>
                        <Border Grid.Column="1" Margin="10,0,0,0" Background="#e0e0e0" Padding="15">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Live Alpha/Beta" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="FftRatioText" Text="0.00" FontSize="36" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            
            <!-- Tab 2: Band Power Trends -->
            <TabItem Header="Band Power Trends">
                <Grid>
                    <ScottPlot:WpfPlot x:Name="TrendPlot" Margin="5"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: Neurofeedback (Audio) -->
            <TabItem Header="Neurofeedback Training">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScottPlot:WpfPlot x:Name="NfFftPlot" Grid.Column="0"/>
                        <Border Grid.Column="1" Margin="10,0,0,0" Background="#e0e0e0" Padding="15">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Live Alpha/Beta" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="NfRatioText" Text="0.00" FontSize="48" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <Border Grid.Row="1" Margin="20" Background="#f8f8f8" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Auditory Feedback Training" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="A continuous tone will play. As your selected ratio (e.g. Alpha/Beta) increases, the tone volume will proportionally decrease. Silence means success." TextWrapping="Wrap" Margin="0,0,0,20"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Enable Audio Tone:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                    <CheckBox x:Name="AudioEnableCheckbox" Checked="AudioEnable_Checked" Unchecked="AudioEnable_Unchecked" VerticalAlignment="Center">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Button x:Name="BrowseAudioButton" Content="Browse Custom Audio..." Width="150" Padding="5" Margin="0,0,10,0" Click="BrowseAudio_Click"/>
                                    <TextBlock x:Name="LoadedAudioText" Text="Using Built-in Tone (432Hz)" VerticalAlignment="Center" FontStyle="Italic"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Master Volume:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" Width="140"/>
                                    <Slider x:Name="MasterVolumeSlider" Minimum="0" Maximum="1" Value="0.5" Width="200" ValueChanged="MasterVolumeSlider_ValueChanged"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Current Audio Volume: " FontWeight="Bold" VerticalAlignment="Center" Width="140"/>
                                    <ProgressBar x:Name="VolumeProgressBar" Minimum="0" Maximum="1" Value="0" Width="200" Height="20" Foreground="Green"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                <TextBlock Text="Personal Baseline Calibration" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <Button x:Name="CalibrateButton" Content="Start 60s Calibration" Width="200" Height="40" FontSize="14" FontWeight="Bold" Click="CalibrateButton_Click"/>
                                <TextBlock x:Name="CalibrationStatusText" Text="Ready" HorizontalAlignment="Center" Margin="0,10,0,5" FontStyle="Italic"/>
                                <ProgressBar x:Name="CalibrationProgressBar" Minimum="0" Maximum="60" Value="0" Width="200" Height="15"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Tab 4: Settings & Tuning -->
            <TabItem Header="Settings &amp; Tuning">
                <StackPanel Margin="20">
                    <TextBlock Text="Artifact Rejection Threshold (uV)" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="ThresholdSlider" Minimum="50" Maximum="500" Value="150" Width="300" 
                                TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="ThresholdSlider_ValueChanged"/>
                        <TextBlock x:Name="ThresholdValueText" Text="150 uV" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="Lower values reject more data (stricter). Higher values allow more artifacts through." 
                               Foreground="Gray" Margin="0,5,0,20"/>

                    <TextBlock Text="Bandpass Filter (Low-Cut Hz)" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="LowCutSlider" Minimum="0.5" Maximum="5.0" Value="1.0" Width="300" 
                                TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="FilterSlider_ValueChanged"/>
                        <TextBlock x:Name="LowCutValueText" Text="1.0 Hz" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="Frequencies below this are filtered out (removes drift/sweat)." Foreground="Gray" Margin="0,5,0,20"/>

                    <TextBlock Text="Bandpass Filter (High-Cut Hz)" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="HighCutSlider" Minimum="30.0" Maximum="50.0" Value="40.0" Width="300" 
                                TickFrequency="1.0" IsSnapToTickEnabled="True" ValueChanged="FilterSlider_ValueChanged"/>
                        <TextBlock x:Name="HighCutValueText" Text="40.0 Hz" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="Frequencies above this are filtered out (removes EMG/muscle noise)." Foreground="Gray" Margin="0,5,0,20"/>

                    <TextBlock Text="Neurofeedback Target Ratio Threshold" FontWeight="Bold" Margin="0,15,0,10" FontSize="14"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="TargetRatioSlider" Minimum="0.1" Maximum="3.0" Value="1.0" Width="300" 
                                TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="TargetRatioSlider_ValueChanged"/>
                        <TextBlock x:Name="TargetRatioValueText" Text="1.0" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="If your real-time ratio exceeds this target, the audio tone will completely mute." 
                               Foreground="Gray" Margin="0,5,0,20"/>
                </StackPanel>
            </TabItem>
            <!-- Tab 5: External Tools -->
            <TabItem Header="External Tools">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="External Application Management" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        <WrapPanel Margin="0,0,0,15">
                            <Button x:Name="LaunchEngineButton" Content="Launch Python Engine" Width="200" Height="40" Margin="0,0,15,15" Click="LaunchEngine_Click"/>
                            <Button x:Name="LaunchBlueMuseButton" Content="Launch BlueMuse Stream" Width="200" Height="40" Margin="0,0,15,15" Click="LaunchBlueMuse_Click"/>
                            <Button x:Name="LaunchLabRecorderButton" Content="Launch LabRecorder" Width="200" Height="40" Margin="0,0,15,15" Click="LaunchLabRecorder_Click"/>
                        </WrapPanel>
                        <TextBlock Text="Note: Python Engine outputs will be redirected to the console below." FontStyle="Italic" Foreground="Gray" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <Border Grid.Row="1" Background="#1e1e1e" CornerRadius="5" Padding="5">
                        <TextBox x:Name="ConsoleOutput" IsReadOnly="True" Background="Transparent" Foreground="#d4d4d4" FontFamily="Consolas" BorderThickness="0" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
